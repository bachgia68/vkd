# Sao chép file này thành .env (chỉ dùng cho máy local, KHÔNG commit .env thật lên git).
# Trên Netlify: Site settings → Environment variables → thêm 3 biến dưới đây với giá trị thật
# lấy từ https://my.payos.vn → Kênh thanh toán → Thông tin kết nối.

PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Email báo đơn hàng mới (khi khách thanh toán PayOS thành công).
# Lấy RESEND_API_KEY tại https://resend.com (miễn phí, không cần domain riêng — dùng sender
# mặc định onboarding@resend.dev là gửi được ngay).
RESEND_API_KEY=
ORDER_NOTIFY_EMAIL=mcmpro6688@gmail.com
