# SPA fallback for Apache-based hosting (Hostinger, cPanel, etc.)
# so deep links like /gate-vkd-control-2026/cms don't 404 on refresh.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
